def menu():
    nome = "log.txt"
    while True:
        print("1 - Gerar logs")
        print("2 - Analisar logs")
        print("3 - Gerar e analisar")
        print("4 - Sair")

        op = input("Opção: ")

        if op == "1":
            qtd = int(input("Qtd: "))
            gerar_arquivo_logs(nome, qtd)

        elif op == "2":
            analisar_arquivo_logs(nome)

        elif op == "3":
            qtd = int(input("Qtd: "))
            gerar_arquivo_logs(nome, qtd)
            analisar_arquivo_logs(nome)

        elif op == "4":
            break

        else:
            print("Inválido\n")


menu()
